# RaptorTracker — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Server ────────────────────────────────────────────────────
# Port the Express server listens on
PORT=3000

# Random string used to sign session cookies — make this long and unique
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=changeme-replace-with-a-long-random-string

# ── Admin Account ─────────────────────────────────────────────
# Credentials for the built-in admin user (created on first db:init)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Data Storage ──────────────────────────────────────────────
# Directory where the SQLite database is stored
DATA_DIR=./data

# Directory where uploaded photos, stickers, and attachments are stored
UPLOAD_DIR=./data/uploads

# ── Environment ───────────────────────────────────────────────
# Use "development" locally, "production" on the server
NODE_ENV=development
